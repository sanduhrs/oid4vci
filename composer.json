{
    "name": "openid4vc/oid4vci",
    "description": "Generic PHP library implementing OpenID for Verifiable Credential Issuance 1.0 core protocol",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-json": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "OpenID4VC\\OID4VCI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenID4VC\\OID4VCI\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyze": "phpstan analyse",
        "test": "phpunit",
        "test:coverage": "phpunit -c phpunit.coverage.xml.dist --coverage-text --coverage-clover coverage.xml --coverage-html coverage",
        "lint": "phpcs --runtime-set ignore_warnings_on_exit 1",
        "lint:fix": "phpcbf --runtime-set ignore_warnings_on_exit 1"
    }
}
